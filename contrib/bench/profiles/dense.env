# Dense profile: post-NU5 mainnet, active Orchard/Sapling. BASE picked by sampling
# the shielded commitments added per block (compact-block size driver): ~3.5/block
# around 3.35M vs ~0.65/block at 2.4M. Zcash mainnet is low-volume, so "dense" is
# relative — the point is real shielded content vs the empty pre-Sapling `light`.
# Consumed both as a Compose --env-file and sourced by the harness scripts, so
# keep it plain KEY=value with no quoting or `export`.
PROFILE=dense
BASE=3350000
SPAN=12000
RUST_CACHE_VOLUME=rust-cache-dense
GO_CACHE_VOLUME=go-cache-dense
